{
    "name": "pixelo/avatar-generator",
    "description": "Generate dynamic profile placeholder images for Laravel applications",
    "type": "library",
    "keywords": [
        "laravel",
        "avatar",
        "placeholder",
        "image",
        "profile"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jackson K",
            "email": "jacksonkonjengbam@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/routing": "^10.0|^11.0|^12.0",
        "ext-gd": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^10.11"
    },
    "autoload": {
        "psr-4": {
            "pixelo\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "pixelo\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "pixelo\\PixeloServiceProvider"
            ],
            "aliases": {
                "pixelo": "pixelo\\Facades\\Pixelo"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
